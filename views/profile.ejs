<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css"
      integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/utilities.css" />
    <link rel="stylesheet" href="/css/style.css" />

    <title>Shape||Build you community</title>
  </head>
  <body>
    <!-- top navebar -->
    <section class="nave-bar">
      <div class="container sm flex">
        <a href="/home"
          ><img class="" src="/assets/shape.png" alt="" height="30px"
        /></a>

        <div class="search flex">
          <i class="fa fa-search"></i>
          <input type="text" name="search" placeholder="Search" />
        </div>

        <div class="action">
          <ul class="flex">
            <li>
              <a href="/compose"
                >Create <i class="fa fa-plus" aria-hidden="true"></i
              ></a>
            </li>
            <li>
              <a href=""><i class="fa fa-bell" aria-hidden="true"></i></a>
            </li>
          </ul>
        </div>

        <div class="profile">
          <div class="profile-menu">
            <ul class="flex">
              <li><a href="/profile">Profile</a></li>
              <li><a href="/logout">Logout</a></li>
            </ul>
          </div>
        </div>
      </div>
      </div>
    </section>


    





    <!-- main -->
    <section class="main">
      <div class="container">
        <div class="update"></div>
        <%if (profileUser.id===currentUser.id){%>
         <div class="profile-hero flex">
             <div class="profile-P flex">
              <div class="p-pic">
                 <!-- <img src="" alt=""> -->
              </div>
              <div class="p-name ml-s">
                <h3 style="font-size:1.5rem;"><%=profileUser.first_name%> <%=profileUser.last_name%></h3>
                <p class="mb-s"  style="font-size: small;font-style: italic;color: rgba(0, 0, 0, 0.475);">UniqueName</p>
                </div>
             </div>
             <div class="profile-nav flex">
             
             
              
              <a href="">Post</a>
              <a href="">Comment</a>
              <a href="">Saved</a>
              <a href="">Like</a>
                </div>
              </div>
             <%}else{%> 
              <div class="profile-hero flex">
             <div class="profile-P flex">
              <div class="p-pic">
                 <!-- <img src="" alt=""> -->
              </div>
              <div class="p-name ml-s">
                <h3 style="font-size:1.5rem;"><%=profileUser.first_name%> <%=profileUser.last_name%></h3>
                <p class="mb-s"  style="font-size: small;font-style: italic;color: rgba(0, 0, 0, 0.475)">UniqueName</p>
                </div>
             </div>
             <div class="profile-nav flex">
             
             
              
              <a href="">Post</a>
              <a href="">Comment</a>
              
                </div>
              </div>
              <%}%>
              
       

        <%if (profileUser.id===currentUser.id){%> <%posts.forEach((post,i)=>{%>
        <div class="post-cover" >
        <div class="post" >
          <div class="personal-p flex">
            <a href="/profile/<%=post.user_id%>"
              ><div class="profile-pic">
                <!-- <img class="" src="/assets/google.png" alt="" /> -->
              </div></a
            >

            <a href="/profile/<%=post.user_id%>"
              ><p style="font-size: medium">
                <%=currentUser.first_name%> <%=currentUser.last_name%>
              </p></a
            >
             <div class="p-opt flex" style="margin-left: auto">
              <i class="fa fa-ellipsis-h" aria-hidden="true"></i>
              <div class="p-optD">
               <button
              class="update-btn p-opt-btn"
              data-id="<%=post.id%>"
              data-index="<%=i%>"
              
            >
              <i class="fa fas fa-pencil-alt" aria-hidden="true"></i> Edit post detail
            </button>
            <form
              action="/delete/<%=post.id%>"
              method="post"
              
            >
              <button  class="p-opt-btn" type="submit">
                <i class="fa fa-trash" aria-hidden="true"></i> Delete
              </button>
            </form>
             </div>
            </div>
           
          </div>

          <h4 class="post-title sm-x"><%=post.title%></h4>

          <% if (post.detail && post.detail.trim() !== "") { %>
          <p class="post-detail sm-x"><%=post.detail%></p>
          <% } %>

          <div class="function flex">
              <button>
                <i class="fa fa-thumbs-up" aria-hidden="true"></i>
                <span>1</span>
              </button>
              <button>
                <i class="fa fa-thumbs-down" aria-hidden="true"></i>
                <span>1</span>
              </button>
              <button>
                <i class="fa fa-comment" aria-hidden="true"></i> <span>1</span>
              </button>
            </div>
        </div>
        </div>
        <%})%> <%}else{%> <% posts.forEach((post)=>{ %>
          <div class="post-cover" >
        <div class="post" >
         

          <div class="personal-p flex">
            <a href="/profile/<%=post.user_id%>"
              ><div class="profile-pic">
                <!-- <img class="" src="/assets/google.png" alt="" /> -->
              </div></a
            >

            <a href="/profile/<%=post.user_id%>"
              ><p style="font-size: medium">
                <%=profileUser.first_name%> <%=profileUser.last_name%>
              </p></a
            >
             <div class="p-opt flex" style="margin-left: auto">
              <i class="fa fa-ellipsis-h" aria-hidden="true"></i>
              <div class="p-optD">
               <button
              class=" p-opt-btn"
              
              
            >
              <i class="fa fa-bookmark" aria-hidden="true"></i> Save
            </button>
            
             </div>
            </div>
           
          </div>

          <h4 class="post-title sm-x"><%=post.title%></h4>

          <% if (post.detail && post.detail.trim() !== "") { %>
          <p class="post-detail sm-x"><%=post.detail%></p>
          <% } %>

         <div class="function flex">
              <button>
                <i class="fa fa-thumbs-up" aria-hidden="true"></i>
                <span>1</span>
              </button>
              <button>
                <i class="fa fa-thumbs-down" aria-hidden="true"></i>
                <span>1</span>
              </button>
              <button>
                <i class="fa fa-comment" aria-hidden="true"></i> <span>1</span>
              </button>
            </div>
        </div>
        </div>
        <%})%> <%}%>
      </div>
    </section>
    <script>
      window.serverData = { posts: <%- JSON.stringify(posts) %> };
    </script>
    <script src="/js/profile.js"></script>
  </body>
</html>
